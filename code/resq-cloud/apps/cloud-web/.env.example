# cloud-dashboard environment variables
#
# Copy this file to .env and adjust for your local setup.
# Do NOT commit .env — it is listed in .gitignore.
#
# LOCAL DEVELOPMENT:
#   Default value below works with the local cloud-api on port 19080.
#
# PRODUCTION (AWS Amplify):
#   Set VITE_CLOUD_API_BASE_URL in the Amplify Console → App settings → Environment variables.
#   Example: https://resq-cloud-api.us-east-1.elasticbeanstalk.com
#   Do NOT commit the production URL here.

VITE_CLOUD_API_BASE_URL=http://localhost:19080
