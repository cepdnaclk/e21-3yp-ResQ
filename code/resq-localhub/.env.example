# Frontend
VITE_HUB_API_BASE_URL=http://localhost:18080

# Backend
HUB_API_PORT=18080

# Local database direction (future wiring)
LOCAL_SQLITE_PATH=./data/localhub.db

# MQTT broker direction
MQTT_HOST=127.0.0.1
MQTT_TCP_PORT=1883
MQTT_WS_PORT=9001
RESQ_MQTT_SECURITY_MODE=development
RESQ_MQTT_BROKER_URL=tcp://localhost:1883
RESQ_MQTT_USERNAME=
RESQ_MQTT_PASSWORD=

# Demo/final dashboard MQTT-over-WebSocket read-only credentials.
# VITE_* values are visible to browser clients. Use only the read-only dashboard user here.
VITE_RESQ_MQTT_WS_URL=ws://localhost:9001
VITE_RESQ_MQTT_DASHBOARD_USERNAME=
VITE_RESQ_MQTT_DASHBOARD_PASSWORD=

# Cloud sync (future)
CLOUD_SYNC_ENABLED=false
