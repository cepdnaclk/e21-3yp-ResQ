{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResQ Local Hub",
  "version": "0.1.0",
  "identifier": "lk.resq.localhub",
  "build": {
    "beforeDevCommand": "pnpm exec vite --host 127.0.0.1 --port 1430",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ResQ Local Hub",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
