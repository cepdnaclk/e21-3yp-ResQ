{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResQ Local Hub",
  "version": "0.1.0",
  "identifier": "lk.resq.localhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ResQ Local Hub",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../../../../../docs/site/assets/img/logo/favicon.ico"]
  }
}
