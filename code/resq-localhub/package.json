{
  "name": "resq-local-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc -b --verbose",
    "clean": "rimraf **/dist **/*.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  }
}