{
	"name": "resq-localhub-workspace",
	"private": true,
	"packageManager": "pnpm@10.33.2",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"typecheck": "pnpm --filter localhub-desktop exec tsc --noEmit",
		"desktop:build": "pnpm --filter localhub-desktop run build",
		"desktop:test": "pnpm --filter localhub-desktop run test",
		"desktop:tauri:dev": "pnpm --filter localhub-desktop tauri dev",
		"desktop:tauri:build": "pnpm --filter localhub-desktop tauri build",
		"backend:test": "cd services/hub-api && .\\mvnw.cmd test",
		"verify": "pnpm run typecheck && pnpm run desktop:build && pnpm run desktop:test && pnpm run backend:test",
		"dev:localhub": "pnpm --filter localhub-desktop run tauri:dev"
	}
}
