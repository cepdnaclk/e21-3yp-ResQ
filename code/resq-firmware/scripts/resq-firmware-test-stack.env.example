## Example env file for local developer settings.
## Copy this to `resq-firmware-test-stack.env` next to this script and fill values.
## DO NOT commit your real credentials — use the .example as a template.

# Repository root (optional). If empty, parent of `scripts/` is used.
REPO_ROOT=

# Device identification
DEVICE_ID=RESQ-DEV-001

# Serial / COM port (e.g., COM3 or /dev/ttyUSB0)
COM_PORT=

# MQTT broker
BROKER_HOST=localhost
MQTT_PORT=1883

# Backend host (API)
BACKEND_HOST=http://localhost:8080

# Device auth token (placeholder)
AUTH_TOKEN=your_auth_token_here

# Ports used for mock register or test helpers
MOCK_REGISTER_PORT=5000

# Wi‑Fi credentials (use placeholder values here; do NOT commit real passwords)
WIFI_SSID=YourWiFiSSID
WIFI_PASSWORD=YourWiFiPassword

# Flags (true/false)
USE_WINDOWS_TERMINAL=false
SKIP_MONITOR=false
SKIP_QR=false
RUN_MQTT_TESTS=false
USE_DOCKER_BROKER=false
